    @GET("quote/{tickers}")
    suspend fun getQuotes(
        @Path("tickers") tickers: String,
        @Query("range") range: String = "1d",
        @Query("interval") interval: String = "1d",
        @Query("fundamental") fundamental: Boolean = false,
        @Query("dividends") dividends: Boolean = false,
    ): QuoteResponseDto

    @GET("quote/list")
